<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.StealthVault" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">@bool/is_light_mode</item>
    </style>

    <!-- Theme for the Calculator Disguise -->
    <style name="Theme.StealthVault.NoActionBar" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">@bool/is_light_mode</item>
        <item name="android:windowContentTransitions">true</item>
    </style>
</resources>
