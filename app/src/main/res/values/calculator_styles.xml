<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Calculator Button Base Style -->
    <style name="CalculatorButtonStyle" parent="Widget.Material3.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="app:layout_constraintDimensionRatio">1:1</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">26sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="backgroundTint">@color/calc_button_number</item>
        <item name="cornerRadius">100dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:padding">0dp</item>
    </style>

    <style name="CalculatorButtonStyle.Operator" parent="CalculatorButtonStyle">
        <item name="backgroundTint">@color/calc_button_operator</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="CalculatorButtonStyle.Action" parent="CalculatorButtonStyle">
        <item name="backgroundTint">@color/calc_button_special</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="CalculatorButtonStyle.Scientific" parent="CalculatorButtonStyle">
        <item name="backgroundTint">@color/surface</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">16sp</item>
    </style>
</resources>
